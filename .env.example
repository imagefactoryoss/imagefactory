# Image Factory Configuration
# This file contains example environment variables
# Copy to .env.development or .env.production and update values

# ============================================================================
# Server Configuration
# ============================================================================
IF_SERVER_PORT=8080
IF_SERVER_HOST=0.0.0.0
IF_SERVER_ENVIRONMENT=development
IF_SERVER_VERSION=1.0.0
IF_SERVER_READ_TIMEOUT=30s
IF_SERVER_WRITE_TIMEOUT=30s

# ============================================================================
# Database Configuration
# ============================================================================
IF_DATABASE_HOST=localhost
IF_DATABASE_PORT=5432
IF_DATABASE_NAME=image_factory
IF_DATABASE_USER=postgres
IF_DATABASE_PASSWORD=postgres
IF_DATABASE_SSL_MODE=disable
IF_DATABASE_SCHEMA=public
IF_DATABASE_MAX_OPEN_CONNS=25
IF_DATABASE_MAX_IDLE_CONNS=5
IF_DATABASE_CONN_MAX_LIFETIME=5m

# ============================================================================
# Authentication Configuration - JWT
# ============================================================================
# CRITICAL: JWT Secret must be set for authentication to work
# Use a strong, random string (minimum 32 characters)
# Generate with: openssl rand -base64 32
IF_AUTH_JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars
IF_AUTH_JWT_EXPIRATION=24h
IF_AUTH_REFRESH_TOKEN_EXP=168h

# ============================================================================
# Authentication Configuration - LDAP
# ============================================================================
IF_AUTH_LDAP_ENABLED=false
IF_AUTH_LDAP_SERVER=localhost
IF_AUTH_LDAP_PORT=389
IF_AUTH_LDAP_BASE_DN=dc=example,dc=com
IF_AUTH_LDAP_BIND_DN=cn=admin,dc=example,dc=com
IF_AUTH_LDAP_BIND_PASSWORD=admin-password
IF_AUTH_LDAP_USER_SEARCH_BASE=ou=users,dc=example,dc=com
IF_AUTH_LDAP_GROUP_SEARCH_BASE=ou=groups,dc=example,dc=com
IF_AUTH_LDAP_USE_TLS=false
IF_AUTH_LDAP_START_TLS=false
IF_AUTH_LDAP_ALLOWED_DOMAINS=example.com

# ============================================================================
# Authentication Configuration - SAML
# ============================================================================
IF_AUTH_SAML_ENABLED=false
IF_AUTH_SAML_METADATA_URL=

# ============================================================================
# Logger Configuration
# ============================================================================
IF_LOGGER_LEVEL=info
IF_LOGGER_FORMAT=json
IF_LOGGER_OUTPUT_PATH=stdout

# ============================================================================
# NATS Configuration (Event Bus)
# ============================================================================
IF_NATS_URLS=nats://localhost:4222
IF_NATS_MAX_RECONNECTS=3
IF_NATS_RECONNECT_WAIT=2s
IF_NATS_TIMEOUT=10s
IF_NATS_SUBJECT=image-factory
IF_NATS_CLUSTER_ID=image-factory-cluster
IF_NATS_CLIENT_ID=image-factory-server

# ============================================================================
# Redis Configuration (Caching)
# ============================================================================
IF_REDIS_HOST=localhost
IF_REDIS_PORT=6379
IF_REDIS_PASSWORD=
IF_REDIS_DB=0
IF_REDIS_POOL_SIZE=10
IF_REDIS_IDLE_TIMEOUT=5m
IF_REDIS_READ_TIMEOUT=3s
IF_REDIS_WRITE_TIMEOUT=3s

# ============================================================================
# Build Configuration
# ============================================================================
IF_BUILD_DEFAULT_TIMEOUT=30m
IF_BUILD_MAX_CONCURRENT_JOBS=10
IF_BUILD_WORKER_POOL_SIZE=5
IF_BUILD_STORAGE_PATH=/tmp/image-factory
IF_BUILD_REGISTRY_URL=localhost:5000

# Workflow Orchestrator Configuration
IF_WORKFLOW_ENABLED=true

# Internal Registry Temp Cleanup Worker
IF_INTERNAL_REGISTRY_TEMP_CLEANUP_ENABLED=true
IF_INTERNAL_REGISTRY_TEMP_CLEANUP_RETENTION_HOURS=72
IF_INTERNAL_REGISTRY_TEMP_CLEANUP_INTERVAL_MINUTES=60
IF_INTERNAL_REGISTRY_TEMP_CLEANUP_BATCH_SIZE=100
IF_INTERNAL_REGISTRY_TEMP_CLEANUP_DRY_RUN=false
IF_INTERNAL_REGISTRY_GC_WORKER_PORT=8085
IF_INTERNAL_REGISTRY_GC_TLS_ENABLED=false
IF_INTERNAL_REGISTRY_GC_INSECURE_SKIP_TLS_VERIFY=false
# Optional auth for private registry API access
# IF_INTERNAL_REGISTRY_GC_USERNAME=
# IF_INTERNAL_REGISTRY_GC_PASSWORD=
# IF_INTERNAL_REGISTRY_GC_BEARER_TOKEN=
IF_INTERNAL_TEMP_SCAN_REGISTRY=image-factory-registry:5000
IF_INTERNAL_TEMP_SCAN_REPOSITORY=quarantine-temp

# ============================================================================
# SMTP Configuration (Email)
# ============================================================================
IF_SMTP_HOST=localhost
IF_SMTP_PORT=1025
IF_SMTP_USERNAME=
IF_SMTP_PASSWORD=
IF_SMTP_USE_TLS=false
IF_SMTP_FROM_EMAIL=noreply@example.com

# ============================================================================
# AWS/S3 Configuration (if using S3 for storage)
# ============================================================================
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=image-factory-builds

# ============================================================================
# Development Notes
# ============================================================================
# For local development, you can use .env.development
# For testing, you can use .env.test
# For production, use .env.production with actual values
# 
# Sensitive values (passwords, secrets) should NEVER be committed to git
# Use environment variables or secrets management in production
